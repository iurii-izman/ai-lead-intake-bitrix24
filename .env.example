APP_NAME=AI Lead Intake for Bitrix24
ENVIRONMENT=demo
DEBUG=true
APP_BASE_URL=http://localhost:8000

DATABASE_URL=sqlite+pysqlite:///./data/app.db
DATABASE_ECHO=false

INTAKE_WEBHOOK_SECRET=change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Demo-first default:
# Keep AI mock until the local baseline is stable.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
CONFIDENCE_THRESHOLD=0.75

# Demo-first default:
# Use mock mode for local demo and screenshots.
# For the first real portal validation, prefer switching only this boundary to real
# while keeping AI_PROVIDER=mock.
BITRIX_MODE=mock
# Choose:
# - legacy for classic lead-based portals
# - universal when crm.item.add with entityTypeId=1 matches the portal path
BITRIX_CRM_MODE=universal
# Keep only in local .env. Never commit a real webhook URL.
BITRIX24_WEBHOOK_URL=
# Optional explicit portal base URL used for nicer entity links in the admin UI.
BITRIX24_BASE_URL=
BITRIX_TIMEOUT_SECONDS=30

INTAKE_RATE_LIMIT_MAX_REQUESTS=10
INTAKE_RATE_LIMIT_WINDOW_SECONDS=60
# Legacy compatibility with the original TЗ format:
# RATE_LIMIT_INTAKE=10/minute

WORKER_AUTOSTART=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=5
WORKER_MAX_RETRY_ATTEMPTS=3
